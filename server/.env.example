# LLM proxy keys for LOCAL dev. Copy to `server/.env` and fill in.
# (On the VM these live in /etc/bank-interview/proxy.env instead.)
GEMINI_API_KEY=
GROQ_API_KEY=
# optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# PORT=3001
# Self-imposed daily fuse: max chat turns for the WHOLE site per day (0 = off).
# Defense in depth only — it does not prevent billing. The real safeguard is
# keeping both API keys on accounts with NO billing enabled (see deploy docs).
# DAILY_CALL_CAP=2000
