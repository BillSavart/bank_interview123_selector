# Caddy config for the bank-interview site on a GCP e2-micro VM.
#
# Replace YOUR_DOMAIN below. Caddy auto-provisions + renews HTTPS (Let's Encrypt).
# When Cloudflare sits in front in "Full" mode, this still works:
# Cloudflare → VM:443 (TLS terminated again at Caddy).
#
# Install Caddy:  https://caddyserver.com/docs/install  (apt repo)
# Then:           sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

YOUR_DOMAIN {
	encode zstd gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}

	# 經驗分享文章短網址 /e/<slug> → API 302 轉到 /experience/<id>。
	handle /e/* {
		reverse_proxy 127.0.0.1:3000
	}

	# 經驗分享文章的動態 SEO：只有爬蟲 / 社群預覽的 UA 會被導到 API，由 API
	# 回傳帶正確 <head> meta 的文章 HTML；一般使用者照舊走下方靜態 SPA。
	@articlebot {
		path /experience/*
		header_regexp User-Agent (?i)(googlebot|bingbot|duckduckbot|baiduspider|yandex|facebookexternalhit|facebot|twitterbot|linebot|line/|slackbot|telegram|whatsapp|discordbot|applebot|pinterest|redditbot|embedly|skypeuripreview|w3c_validator)
	}
	handle @articlebot {
		reverse_proxy 127.0.0.1:3000
	}

	# Static SPA
	handle {
		root * /var/www/bank-interview
		try_files {path} {path}/index.html /index.html
		file_server
	}

	# long-cache the hashed assets, no-cache the HTML entrypoint
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	@html path /index.html /
	header @html Cache-Control "no-cache"
}

# Admin subdomain — same SPA + API, a tidy separate entry point for the
# 招考行事曆 後台 (/admin). Writes are gated by ADMIN_TOKEN in the API, so this
# subdomain need not be secret. Add a DNS record for ADMIN_YOUR_DOMAIN first.
# Optional extra hardening: uncomment basic_auth (hash via `caddy hash-password`).
ADMIN_YOUR_DOMAIN {
	encode zstd gzip

	# basic_auth {
	# 	admin <bcrypt-hash-from-caddy-hash-password>
	# }

	handle /api/* {
		reverse_proxy 127.0.0.1:3000
	}

	handle {
		root * /var/www/bank-interview
		try_files {path} {path}/index.html /index.html
		file_server
	}

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	@html path /index.html /
	header @html Cache-Control "no-cache"
}
